{
  "compilerOptions": {
    /* 基础 */
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "moduleResolution": "Bundler",
    /* 关键：JS 兼容 */
    "allowJs": true,
    "checkJs": false,

    /* 不要在这里 strict */
    "strict": true,
    "noImplicitAny": false,

    /* Vue / Vite */
    "jsx": "preserve",
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* 路径别名 */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/api/*": ["src/api/*"],
      "@/components/*": ["src/components/*"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.ts",
    "**/*.d.ts",
    "**/*.tsx",
    "**/*.vue",
    ".nuxt/**/*.d.ts",
    "auto-imports.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist", ".output"]
}
